# Comma-separated list of valid API keys for inbound requests
KAAS_API_KEYS=dev-key-1,dev-key-2

# Feature flags
KAAS_GRAPH_ENABLED=false

# Retriever defaults
KAAS_DEFAULT_TOP_K=5
KAAS_DEFAULT_MAX_PRODUCTS=3

# MCP server — base URL of the running REST API
KAAS_BASE_URL=http://localhost:8000
KAAS_MCP_API_KEY=dev-key-1
